# --- Frontend Environment Variables (.env) ---

# Backend API Base URL (Proxy or direct)
VITE_API_URL=http://localhost:5000/api

# Frontend Development Server Port
VITE_PORT=3000

# ML Service URL (If used directly by frontend)
VITE_ML_SERVICE_URL=http://localhost:8000

# Application Identity
VITE_APP_NAME=MedEcho
VITE_APP_VERSION=1.0.0

# External APIs (Optional/Project Specific)
# GEMINI_API_KEY=your_gemini_api_key_here
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Note: All variables starting with VITE_ are automatically 
# available in your React code via import.meta.env.VITE_VARIABLE_NAME